NEBIUS_API_KEY=your_key_here
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1
NEBIUS_MODEL=Qwen/Qwen3-32B-fast
MAX_REPO_ZIP_MB=150
MAX_LLM_INPUT_TOKENS=22000
MAX_TREE_CHARS=12000
MAX_TOTAL_FILES_CHARS=80000
MAX_FILE_CHARS=2500
MAX_README_CHARS=9000
MAX_FILES=35
# Optional: GitHub token to avoid unauthenticated rate limits (common 403 failure mode in repeated tests).
# If set, requests to api.github.com include: Authorization: Bearer <token>
GITHUB_TOKEN=
